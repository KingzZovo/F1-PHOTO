# F1-Photo server environment
# Copy to .env and edit. .env is gitignored.

# HTTP bind address
F1P_BIND=0.0.0.0:8080

# PostgreSQL connection string
# Production default port is 5544; dev uses Ubuntu apt cluster on 5433.
F1P_DATABASE_URL=postgres://f1photo:f1photo_dev@127.0.0.1:5433/f1photo_dev

# JWT signing secret. Generate with: openssl rand -hex 32
# Must be at least 32 chars. Rotate invalidates all sessions.
F1P_JWT_SECRET=change_me_change_me_change_me_change_me_64chars_total_minimum_xx

# Data directory (orig / thumb / archive / annotated subdirs)
F1P_DATA_DIR=./data

# Per-file upload limit in MB (also enforced by `upload.max_mb` setting in DB)
F1P_MAX_UPLOAD_MB=10

# Optional: log filter override (default: info,sqlx=warn,hyper=warn,tower_http=info)
# F1P_LOG=debug,sqlx=info
