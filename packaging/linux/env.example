# Copy to /etc/f1photo/env (chmod 600, owned by f1photo:f1photo)

# Bind only to loopback when fronted by nginx; bind 0.0.0.0 to expose directly.
F1P_BIND=0.0.0.0:8080

# 32+ chars; rotate with care, all sessions invalidate.
F1P_JWT_SECRET=change-me-32-character-secret-rotate-on-incident

# Bundled PG (recommended for offline hosts).
F1P_USE_BUNDLED_PG=1
F1P_BUNDLED_PG_DIR=/opt/f1photo/bundled-pg/bin
F1P_BUNDLED_PG_DATA=/opt/f1photo/bundled-pg-data
F1P_BUNDLED_PG_PORT=5544
F1P_BUNDLED_PG_PASSWORD=please-rotate-me

# If you point at an external PG instead, leave F1P_USE_BUNDLED_PG unset and
# define F1P_DATABASE_URL explicitly:
# F1P_DATABASE_URL=postgres://f1photo:****@db.internal:5432/f1photo_prod

F1P_DATA_DIR=/opt/f1photo/data
F1P_MODELS_DIR=/opt/f1photo/models
F1P_MAX_UPLOAD_MB=20
F1P_INFERENCE_THREADS=4

# Optional: tool-pipeline YOLO proposal noise filter (COCO class blacklist)
# Enable: set to 1. Default off.
F1P_TOOL_YOLO_CLASS_FILTER=0
# Comma-separated COCO class IDs to drop before DINOv2 embedding + recall.
# Default recommended: 0(person),27(tie) based on the 119-photo Asian ID cohort.
F1P_TOOL_YOLO_CLASS_BLACKLIST=0,27

# ONNX Runtime — point at the libonnxruntime.so shipped in the release
# tarball under runtime/.
ORT_DYLIB_PATH=/opt/f1photo/runtime/libonnxruntime.so.1.18.0
